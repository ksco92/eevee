{
    "specVersion": "0",
    "description": "Table with a hand-written AWS Glue DQDL pass-through.",
    "tableType": "hive_parquet",
    "isRawData": true,
    "columns": [
        {
            "name": "widget_id",
            "type": "bigint",
            "description": "Primary key."
        },
        {
            "name": "weight",
