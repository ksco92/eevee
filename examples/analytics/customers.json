{
    "$schema": "https://raw.githubusercontent.com/ksco92/eevee/main/packages/core/src/schema/table.schema.json",
    "specVersion": "0",
    "description": "One row per customer with derived attributes.",
    "tableType": "postgres_18",
    "isRawData": false,
    "columns": [
        {
            "name": "customer_id",
            "type": "bigint",
            "description": "Surrogate customer key.",
            "identity": "always"
        },
        {
            "name": "email",
            "type": "varchar(320)",
            "description": "Customer email address.",
            "collation": "en_US",
            "compression": "lz4",
            "storage": "extended"
        },
        {
            "name": "lifetime_value",
            "type": "numeric(12,2)",
            "description": "Total spend to date."
        },
        {
            "name": "is_active",
            "type": "boolean",
            "description": "Whether the customer is active.",
            "default": "true"
        },
        {
            "name": "lifetime_value_cents",
            "type": "bigint",
            "description": "Lifetime value in cents (generated).",
            "generated": "stored",
            "expression": "lifetime_value * 100",
            "expressionColumns": [
                "lifetime_value"
            ]
        }
    ],
    "primaryKey": [
        "customer_id"
    ],
    "indexes": [
        {
            "name": "idx_customers_email",
            "method": "btree",
            "unique": true,
            "columns": [
                {
                    "name": "email",
                    "sort": "asc",
                    "nulls": "last"
                }
            ],
            "include": [
                "is_active"
            ]
        }
    ],
    "uniqueConstraints": [
        {
            "name": "uq_customers_email",
            "columns": [
                "email"
            ]
        }
    ],
    "checkConstraints": [
        {
            "name": "ck_customers_ltv_nonnegative",
            "expression": "lifetime_value >= 0",
            "columns": [
                "lifetime_value"
            ]
        }
    ],
    "dependsOn": [
        "raw.customers_raw"
    ],
    "foreignKeys": [
        {
            "sourceTable": "raw.customers_raw",
            "sourceColumn": "id",
            "localColumn": "customer_id",
            "allowNulls": false
        }
    ]
}
