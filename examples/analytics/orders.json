{
    "$schema": "https://raw.githubusercontent.com/ksco92/eevee/main/packages/core/src/schema/table.schema.json",
    "specVersion": "0",
    "description": "One row per order placed by a customer.",
    "tableType": "iceberg_parquet_v2",
    "isRawData": false,
    "formatVersion": 2,
    "columns": [
        {
            "name": "order_id",
            "type": "long",
            "description": "Unique order identifier.",
            "nullable": false
        },
        {
            "name": "customer_id",
            "type": "long",
            "description": "Customer who placed the order."
        },
        {
            "name": "order_ts",
            "type": "timestamp",
            "description": "When the order was placed."
        },
        {
            "name": "amount",
            "type": "decimal(12,2)",
            "description": "Order total."
        }
    ],
    "primaryKey": [
        "order_id"
    ],
    "identifierFields": [
        "order_id"
    ],
    "dependsOn": [
        "analytics.customers",
        "raw.events_raw"
    ],
    "partitions": [
        {
            "name": "order_ts",
            "type": "month",
            "description": "Monthly partition derived from the order timestamp."
        }
    ],
    "sortOrder": [
        {
            "column": "order_id",
            "direction": "asc",
            "nullOrder": "nulls-first"
        },
        {
            "column": "order_ts",
            "transform": "day",
            "direction": "desc",
            "nullOrder": "nulls-last"
        }
    ],
    "foreignKeys": [
        {
            "sourceTable": "analytics.customers",
            "sourceColumn": "customer_id",
            "localColumn": "customer_id",
            "allowNulls": false
        }
    ]
}
