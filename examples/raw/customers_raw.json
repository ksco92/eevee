{
    "$schema": "https://raw.githubusercontent.com/ksco92/eevee/main/packages/core/src/schema/table.schema.json",
    "specVersion": "0",
    "description": "Raw customer records as landed from the source system.",
    "tableType": "hive_parquet",
    "isRawData": true,
    "columns": [
        {
            "name": "id",
            "type": "bigint",
            "description": "Source customer identifier."
        },
        {
            "name": "email",
            "type": "string",
            "description": "Customer email address."
        },
        {
            "name": "signup_amount",
            "type": "decimal(10,2)",
            "description": "Initial deposit at signup."
        }
    ],
    "primaryKey": [
        "id"
    ],
    "partitions": [
        {
            "name": "load_date",
            "type": "date",
            "description": "Daily ingestion partition."
        }
    ]
}
