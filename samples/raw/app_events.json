{
    "$schema": "https://raw.githubusercontent.com/ksco92/eevee/main/packages/core/src/schema/table.schema.json",
    "specVersion": "0",
    "description": "Raw mobile app events as landed (Iceberg/Parquet).",
    "tableType": "iceberg_parquet_v2",
    "isRawData": true,
    "formatVersion": 2,
    "columns": [
        {
            "name": "event_id",
            "type": "long",
            "description": "Unique event identifier.",
            "nullable": false
        },
        {
            "name": "user_id",
            "type": "long",
            "description": "User the event belongs to."
        },
        {
            "name": "region",
            "type": "string",
            "description": "Region code."
        },
        {
            "name": "email",
            "type": "string",
            "description": "User email."
        },
        {
            "name": "event_ts",
            "type": "timestamp",
            "description": "Event timestamp (no zone)."
        },
        {
            "name": "event_date",
            "type": "date",
            "description": "Event calendar date."
        },
        {
            "name": "created_tz",
            "type": "timestamptz",
            "description": "Creation timestamp (UTC)."
        },
        {
            "name": "session_dur",
            "type": "time",
            "description": "Session duration as a time of day."
        },
        {
            "name": "amount",
            "type": "decimal(12,4)",
            "description": "Monetary amount."
        },
        {
            "name": "token",
            "type": "uuid",
            "description": "Idempotency token."
        },
        {
            "name": "hash",
            "type": "fixed[16]",
            "description": "Fixed-width content hash."
        },
        {
            "name": "raw_bytes",
            "type": "binary",
            "description": "Raw event bytes."
        },
        {
            "name": "active",
            "type": "boolean",
            "description": "Whether the session was active."
        },
        {
            "name": "count",
            "type": "int",
            "description": "Event count."
        },
        {
            "name": "ratio",
            "type": "float",
            "description": "Sampling ratio."
        },
        {
            "name": "total",
            "type": "double",
            "description": "Running total."
        },
        {
            "name": "sentiment",
            "type": "struct<polarity:double,neg:double,neu:double,pos:double>",
            "description": "Fixed-shape sentiment payload (nested struct type)."
        },
        {
            "name": "tags",
            "type": "list<string>",
            "description": "Free-form tags (nested list type)."
        },
        {
            "name": "attributes",
            "type": "map<string,long>",
            "description": "Arbitrary numeric attributes keyed by name (nested map type)."
        }
    ],
    "primaryKey": [
        "event_id"
    ],
    "partitions": [
        {
            "name": "event_date",
            "type": "year",
            "description": "Year of the event date."
        },
        {
            "name": "event_ts",
            "type": "month",
            "description": "Month of the event timestamp."
        },
        {
            "name": "event_ts",
            "type": "day",
            "description": "Day of the event timestamp (a second transform on the same column)."
        },
        {
            "name": "created_tz",
            "type": "hour",
            "description": "Hour of the creation timestamp."
        },
        {
            "name": "user_id",
            "type": "bucket[16]",
            "description": "Hash-bucket the user id into 16 buckets."
        },
        {
            "name": "email",
            "type": "truncate[8]",
            "description": "Truncate the email to 8 characters."
        },
        {
            "name": "region",
            "type": "identity",
            "description": "Partition by the region value unchanged."
        },
        {
            "name": "user_id",
            "type": "void",
            "description": "Always-null partition (spec-evolution placeholder) on the user id."
        }
    ],
    "identifierFields": [
        "event_id"
    ],
    "tableProperties": {
        "write.format.default": "parquet",
        "write.parquet.compression-codec": "zstd",
        "write.parquet.compression-level": "9",
        "write.distribution-mode": "hash",
        "write.target-file-size-bytes": "536870912",
        "history.expire.max-snapshot-age-ms": "604800000",
        "history.expire.min-snapshots-to-keep": "5",
        "commit.retry.num-retries": "4",
        "commit.retry.min-wait-ms": "100",
        "commit.retry.max-wait-ms": "60000",
        "commit.retry.total-timeout-ms": "1800000"
    }
}
